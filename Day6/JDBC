http://tomcat.apache.org/tomcat-7.0-doc/api/org/apache/tomcat/jdbc/pool/PoolConfiguration.html

import org.springframework.jmx.support.MBeanServerFactoryBean
import org.springframework.jmx.export.MBeanExporter
import org.apache.log4j.jmx.HierarchyDynamicMBean

beans {

    log4jBean(HierarchyDynamicMBean)

    mbeanServer(MBeanServerFactoryBean) {
        locateExistingServerIfPossible = true
    }

    poolBean(org.springframework.beans.factory.config.MethodInvokingFactoryBean)
 {
        targetObject = ref("dataSource")
        targetMethod = "getPool"
    }
    jdbcPoolBean(org.springframework.beans.factory.config.MethodInvokingFactoryB
ean) {
        targetObject = ref("poolBean")
        targetMethod = "getJmxPool"
    }

    exporter(MBeanExporter) {
        server = mbeanServer
        beans = [
            "log4j:hierarchy=default": log4jBean
        ]
    }


    dataSource(org.apache.tomcat.jdbc.pool.DataSource) { bean ->
        bean.destroyMethod = 'close'
        driverClassName = application.config.dataSource.driverClassName
        validationQuery = application.config.dataSource.validationQuery

        username    = application.config.dataSource.username
        password    = application.config.dataSource.password
        url         = application.config.dataSource.url
        initialSize = 25
        maxActive   = 150
        maxIdle     = 25
        minIdle     = 5
        maxWait     = 15000
        maxAge      = 3600 * 1000

        minEvictableIdleTimeMillis    = 60000
        timeBetweenEvictionRunsMillis = 60000

        testOnBorrow = true
        testOnReturn = true

        jmxEnabled   = true

        logAbandoned    = true
    }
}



